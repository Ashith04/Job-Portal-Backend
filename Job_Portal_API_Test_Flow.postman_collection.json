{
  "info": {
    "name": "Job Portal API Test Flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Register Employer",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.data && jsonData.data.accessToken) {",
              "    pm.collectionVariables.set(\"employerToken\", jsonData.data.accessToken);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Tech Corp\",\n    \"email\": \"employer@techcorp.com\",\n    \"password\": \"password123\",\n    \"role\": \"employer\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "2. Login Employer",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.data && jsonData.data.accessToken) {",
              "    pm.collectionVariables.set(\"employerToken\", jsonData.data.accessToken);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"employer@techcorp.com\",\n    \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "3. Create a Job (Employer)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.data && jsonData.data.job) {",
              "    pm.collectionVariables.set(\"jobId\", jsonData.data.job._id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{employerToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Senior Node.js Developer\",\n  \"description\": \"We are looking for an experienced Node.js developer to build scalable REST APIs for our main platform.\",\n  \"skillsRequired\": [\"Node.js\", \"MongoDB\", \"Express.js\"],\n  \"tags\": [\"backend\", \"nodejs\", \"api\"],\n  \"employmentType\": \"full-time\",\n  \"experienceLevel\": \"senior\",\n  \"salary\": { \"min\": 800000, \"max\": 1500000, \"currency\": \"INR\", \"period\": \"yearly\" },\n  \"location\": { \"city\": \"Bangalore\", \"state\": \"Karnataka\", \"country\": \"India\" },\n  \"deadline\": \"2028-12-31\",\n  \"openings\": 2\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employer/jobs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employer",
            "jobs"
          ]
        }
      }
    },
    {
      "name": "4. Register Job Seeker",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.data && jsonData.data.accessToken) {",
              "    pm.collectionVariables.set(\"jobSeekerToken\", jsonData.data.accessToken);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Jane Doe\",\n    \"email\": \"jane.doe@example.com\",\n    \"password\": \"password123\",\n    \"role\": \"jobseeker\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "5. Login Job Seeker",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.data && jsonData.data.accessToken) {",
              "    pm.collectionVariables.set(\"jobSeekerToken\", jsonData.data.accessToken);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"jane.doe@example.com\",\n    \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "6. Apply for Job (Job Seeker)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jobSeekerToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"coverLetter\": \"Hi, I am extremely interested in this Senior Node.js Developer position and I have 5 years of experience scaling MongoDB backends.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/jobseeker/jobs/{{jobId}}/apply",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "jobseeker",
            "jobs",
            "{{jobId}}",
            "apply"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "employerToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "jobSeekerToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "jobId",
      "value": "",
      "type": "string"
    }
  ]
}
